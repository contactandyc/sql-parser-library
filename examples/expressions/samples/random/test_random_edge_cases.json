{
  "table": {
    "name": "edge_cases",
    "columns": [
      { "name": "id", "type": "STRING" },
      { "name": "str_val", "type": "STRING" },
      { "name": "num_val", "type": "DOUBLE" },
      { "name": "int_val", "type": "INT" },
      { "name": "null_col", "type": "INT" }
    ],
    "rows": [
      { "id": "1", "str_val": "  hello world  ", "num_val": 3.14159, "int_val": -10, "null_col": null },
      { "id": "2", "str_val": "SQLEngine", "num_val": -2.5, "int_val": 0, "null_col": null },
      { "id": "3", "str_val": null, "num_val": null, "int_val": null, "null_col": null }
    ]
  },
  "queries": [
    {
      "sql": "TRIM(str_val) = 'hello world'",
      "expected": ["1"],
      "explanation": "Tests leading and trailing whitespace removal."
    },
    {
      "sql": "UPPER(SUBSTR(str_val, 3, 5)) = 'HELLO'",
      "expected": ["1"],
      "explanation": "Tests 1-based SQL substring indexing combined with function chaining. Index 3 of '  hello world  ' is 'h'."
    },
    {
      "sql": "LENGTH(str_val) = 15",
      "expected": ["1"],
      "explanation": "Validates string length calculation includes spaces."
    },
    {
      "sql": "ROUND(num_val, 2) = 3.14",
      "expected": ["1"],
      "explanation": "Tests double-precision rounding with a secondary parameter."
    },
    {
      "sql": "CEIL(num_val) = 4",
      "expected": ["1"],
      "explanation": "Ceiling of 3.14159 is 4."
    },
    {
      "sql": "FLOOR(num_val) = -3",
      "expected": ["2"],
      "explanation": "Floor of -2.5 goes DOWN to -3."
    },
    {
      "sql": "COALESCE(null_col, int_val, 99) = -10",
      "expected": ["1"],
      "explanation": "Tests variadic COALESCE bypassing the first NULL and returning the second valid column."
    },
    {
      "sql": "COALESCE(null_col, int_val, 99) = 99",
      "expected": ["3"],
      "explanation": "Tests variadic COALESCE falling all the way back to the literal integer."
    },
    {
      "sql": "num_val / int_val IS NULL",
      "expected": ["2", "3"],
      "explanation": "Row 2 tests Division by Zero (which should safely return NULL, not crash). Row 3 tests NULL / NULL."
    },
    {
      "sql": "CONCAT(TRIM(str_val), '!', '!') = 'hello world!!'",
      "expected": ["1"],
      "explanation": "Tests variadic string concatenation combined with a nested function."
    }
  ]
}
