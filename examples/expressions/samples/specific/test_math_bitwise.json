{
  "table": {
    "name": "system_flags",
    "columns": [
      { "name": "id", "type": "STRING" },
      { "name": "val", "type": "INT" },
      { "name": "flags", "type": "INT" }
    ],
    "rows": [
      { "id": "1", "val": 10, "flags": 5 },
      { "id": "2", "val": 15, "flags": 2 },
      { "id": "3", "val": 20, "flags": 4 }
    ]
  },
  "queries": [
    {
      "sql": "val % 10 = 0",
      "expected": ["1", "3"],
      "explanation": "10 % 10 = 0, 20 % 10 = 0, but 15 % 10 = 5."
    },
    {
      "sql": "val ^ 2 = 100",
      "expected": ["1"],
      "explanation": "10 squared is 100."
    },
    {
      "sql": "flags & 4 > 0",
      "expected": ["1", "3"],
      "explanation": "Bitwise AND. 5 (101) & 4 (100) = 4. 4 & 4 = 4. 2 (010) & 4 = 0."
    },
    {
      "sql": "flags | 1 = 5",
      "expected": ["1", "3"],
      "explanation": "Bitwise OR. 5 | 1 = 5, 4 | 1 = 5."
    },
    {
      "sql": "val << 1 = 20",
      "expected": ["1"],
      "explanation": "Bitwise left shift. 10 << 1 is 20."
    },
    {
      "sql": "val >> 1 = 5",
      "expected": ["1"],
      "explanation": "Bitwise right shift. 10 >> 1 is 5."
    }
  ]
}
