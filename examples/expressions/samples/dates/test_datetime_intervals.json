{
  "table": {
    "name": "shipping_logs",
    "columns": [
      { "name": "id", "type": "STRING" },
      { "name": "shipdate", "type": "DATETIME" },
      { "name": "commitdate", "type": "STRING" },
      { "name": "transit_days", "type": "INT" }
    ],
    "rows": [
      { "id": "1", "shipdate": "1995-05-31", "commitdate": "1995-04-13", "transit_days": 48 },
      { "id": "2", "shipdate": "1998-02-12", "commitdate": "1998-01-03", "transit_days": 40 },
      { "id": "3", "shipdate": "1995-05-23", "commitdate": "1995-04-18", "transit_days": 35 },
      { "id": "4", "shipdate": "1994-07-10", "commitdate": "1994-06-09", "transit_days": 31 }
    ]
  },
  "queries": [
    {
      "sql": "commitdate < shipdate - INTERVAL '45' DAY",
      "expected": ["1"],
      "explanation": "Implicitly casts the commitdate string, subtracts 45 days from shipdate, and evaluates the inequality."
    },
    {
      "sql": "EXTRACT(YEAR FROM shipdate) = 1995",
      "expected": ["1", "3"],
      "explanation": "Extracts the year integer from the DATETIME column."
    },
    {
      "sql": "shipdate - commitdate > 40",
      "expected": ["1"],
      "explanation": "Subtracts two dates (one string, one datetime) to yield the difference in seconds, which is implicitly cast and evaluated against an INT."
    },
    {
      "sql": "EXTRACT(MONTH FROM commitdate) = 4",
      "expected": ["1", "3"],
      "explanation": "Implicitly casts the commitdate string to a DATETIME before extracting the month."
    }
  ]
}
